# School Management SaaS — Client Environment Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────
# API URL
# ──────────────────────────────
# Leave EMPTY in development — Vite proxies /api requests to localhost:5000
# automatically (see vite.config.ts).
#
# Set this ONLY for production/staging where the API is on a different domain:
# VITE_API_URL=https://api.yourschool.com
VITE_API_URL=
