# ─────────────────────────────────────────────────────────────────────────────
# School Management SaaS — Server Environment Template
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ──────────────────────────────
# SERVER
# ──────────────────────────────
PORT=5000

# development | production
NODE_ENV=development

# ──────────────────────────────
# JWT (CRITICAL)
# ──────────────────────────────
# REQUIRED. Must be ≥ 32 characters in production.
# Generate: openssl rand -hex 32
JWT_SECRET=REPLACE_WITH_A_STRONG_64_CHAR_SECRET

# Session duration. Default: 8h
JWT_EXPIRES_IN=8h

# ──────────────────────────────
# DATABASE
# ──────────────────────────────
# Local development default (SQLite):
DATABASE_URL="file:./prisma/dev.db"

# Production example (PostgreSQL + TLS):
# DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ──────────────────────────────
# CORS (REQUIRED in production)
# ──────────────────────────────
# Comma-separated list of allowed frontend origins.
# Example: CORS_ORIGIN=https://yourapp.com,https://www.yourapp.com
# Leave empty in development (Vite proxy handles it).
CORS_ORIGIN=

# ──────────────────────────────
# PAYSTACK (REQUIRED)
# ──────────────────────────────
# Use sk_test_* for development, sk_live_* for production.
PAYSTACK_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_SECRET_KEY
PAYSTACK_PUBLIC_KEY=pk_test_REPLACE_WITH_YOUR_PUBLIC_KEY

# REQUIRED in production — where Paystack redirects after payment.
PAYSTACK_CALLBACK_URL=http://localhost:5173/payment/verify

# Registration fee in kobo (100 kobo = ₦1). Default: ₦5,000
REGISTRATION_FEE_KOBO=500000

# ──────────────────────────────
# SMTP EMAIL
# ──────────────────────────────
# If not set, OTP emails are logged to console only (dev mode).
# All four vars must be set for SMTP to activate.
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
# Gmail App Password (not your account password):
SMTP_PASS=xxxx xxxx xxxx xxxx
MAIL_FROM=your-email@gmail.com
SUPPORT_EMAIL=support@yourschool.com

# File storage (optional)
# Use an absolute mounted disk path in production for persistent uploads.
# Example (Render persistent disk): /var/data
UPLOADS_BASE_DIR=

# ──────────────────────────────
# OTP
# ──────────────────────────────
# How long a registration OTP stays valid (minutes). Default: 10
REGISTRATION_OTP_MINUTES=10

# ──────────────────────────────
# SUBSCRIPTION / TRIAL
# ──────────────────────────────
# Trial duration after registration payment (days). Default: 7
SCHOOL_TRIAL_DAYS=7

# ──────────────────────────────
# DEV ADMIN BOOTSTRAP
# ──────────────────────────────
# In development, a platform admin is auto-created at startup.
# ALWAYS set this to false in production.
BOOTSTRAP_PLATFORM_ADMIN=true



